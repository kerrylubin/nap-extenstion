        <mxCell id="aYawBRkTkJilWXz14I1b-12" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Need a Proffesion Automation&lt;/h1&gt;&lt;p&gt;- Search for jobs on Indeed, LinkedIn, Magnet.me or Claude in the netherlands or close to where I live, related to what related to what your CV have.&lt;/p&gt;&lt;p&gt;- Upload my CV&lt;/p&gt;&lt;p&gt;- Upload Motivational Letters to use as templates&lt;/p&gt;&lt;p&gt;- Generate unique motivational letter based on the jobs found&lt;/p&gt;&lt;p&gt;- Review the motivational Letters&lt;/p&gt;&lt;p&gt;- Send emails via google mail attached with CV and ML&lt;/p&gt;&lt;p&gt;- Have a list view of a table that shows the following&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Jobs applied to(view of a number)&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Emails sent date&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Interview date&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Rejected date&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- No answer&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Cannot contact&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="400" width="830" x="100" y="40" as="geometry" />
        </mxCell>
        <mxCell id="aYawBRkTkJilWXz14I1b-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Add Links" vertex="1">
          <mxGeometry height="30" width="60" x="250" y="810" as="geometry" />
